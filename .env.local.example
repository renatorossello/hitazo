# ============================================================================
# Cronotema — variables de entorno (sección 10 del PRD)
# Copiá este archivo a .env.local y completá los valores.
# .env.local está en .gitignore: NO se commitea.
# ============================================================================

# --- Spotify (solo el host se loguea; necesita Premium) ---
# Creá la app en https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Debe coincidir EXACTO con un Redirect URI cargado en el dashboard de Spotify.
# En local: http://127.0.0.1:3000/api/auth/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/callback

# --- Supabase ---
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: escribe sin RLS. SOLO server-side, nunca exponer al browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- MusicBrainz ---
# User-Agent identificable obligatorio. Formato: "App/version ( contacto )"
MUSICBRAINZ_USER_AGENT=Hitazo/0.1 ( claude1@rollpix.com )
